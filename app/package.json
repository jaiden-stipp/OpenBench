{
  "name": "openbench",
  "version": "0.1.1",
  "description": "A low-friction desktop workbench for learning and debugging Verilog/SystemVerilog designs.",
  "homepage": "https://github.com/jaiden-stipp/OpenBench",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaiden-stipp/OpenBench.git"
  },
  "author": {
    "name": "Jaiden Stipp",
    "email": "jaidenstipp@gmail.com"
  },
  "license": "GPL-3.0-only",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "start:validation": "electron . --disable-gpu --no-sandbox",
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "build": "tsc --noEmit && vite build",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,js}\" \"electron/**/*.cjs\" \"scripts/**/*.cjs\" \"tests/**/*.mjs\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js}\" \"electron/**/*.cjs\" \"scripts/**/*.cjs\" \"tests/**/*.mjs\" \"eslint.config.js\"",
    "toolchain:stage": "node scripts/stage-toolchain.cjs",
    "package:win:unsigned:dir": "pnpm build && pnpm toolchain:stage && electron-builder --win --dir --config.forceCodeSigning=false",
    "package:win:dir": "node scripts/require-windows-signing.cjs && pnpm build && pnpm toolchain:stage && electron-builder --win --dir --config.forceCodeSigning=true",
    "package:win": "node scripts/require-windows-signing.cjs && pnpm build && pnpm toolchain:stage && electron-builder --win nsis --config.forceCodeSigning=true && node scripts/verify-windows-release.cjs",
    "package:linux:unsigned:dir": "pnpm build && pnpm toolchain:stage && electron-builder --linux --dir",
    "package:linux": "node scripts/require-release-signing.cjs linux && pnpm build && pnpm toolchain:stage && electron-builder --linux deb tar.gz && node scripts/verify-linux-release.cjs",
    "package:mac:unsigned:dir": "pnpm build && pnpm toolchain:stage && electron-builder --mac --dir --config.mac.identity=null --config.mac.hardenedRuntime=false",
    "package:mac": "node scripts/require-release-signing.cjs mac && pnpm build && pnpm toolchain:stage && electron-builder --mac dmg zip --config.forceCodeSigning=true && node scripts/verify-macos-release.cjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "elkjs": "^0.11.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4"
  },
  "build": {
    "appId": "dev.openbench.desktop",
    "productName": "OpenBench",
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "shared/**/*",
      "package.json",
      "LICENSE"
    ],
    "extraResources": [
      {
        "from": ".openbench-toolchain/oss-cad-suite",
        "to": "oss-cad-suite"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "OpenBench-${version}-Windows-${arch}.${ext}",
      "executableName": "OpenBench",
      "icon": "build/icon.ico",
      "signAndEditExecutable": true,
      "signtoolOptions": {
        "publisherName": "Jaiden Stipp"
      }
    },
    "linux": {
      "target": [
        "deb",
        "tar.gz"
      ],
      "artifactName": "OpenBench-${version}-Linux-${arch}.${ext}",
      "executableName": "openbench",
      "maintainer": "Jaiden Stipp <jaidenstipp@gmail.com>",
      "vendor": "OpenBench",
      "synopsis": "Low-friction Verilog and SystemVerilog workbench",
      "description": "OpenBench is a desktop workbench for editing, simulating, inspecting waveforms, and exploring synthesized RTL designs.",
      "category": "Development",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OpenBench-${version}-macOS-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "notarize": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
